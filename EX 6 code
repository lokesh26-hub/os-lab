#include <stdio.h>
#include <unistd.h>
#include <sys/wait.h>  // for wait()

int main() {
    int pid = fork();

    if (pid < 0) {
        printf("Fork Failed\n");
    }
    else if (pid == 0) {
        // Child process
        printf("Child Process\n");
    }
    else {
        // Parent process waits for child
        wait(NULL);
        printf("Parent Process\n");
    }

    return 0;
}
