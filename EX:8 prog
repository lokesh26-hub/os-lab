#include <stdio.h>

int main() {
    int found, flag, l, tp, tr;
    int p[10][10], c[10][10], m[10], r[10], a[10], temp[10];
    int i, j, k = 0, sum = 0;

    printf("Enter total no of processes: ");
    scanf("%d", &tp);

    printf("Enter total no of resources: ");
    scanf("%d", &tr);

    printf("Enter claim (Max. Need) matrix:\n");
    for (i = 0; i < tp; i++) {
        printf("Process %d:\n", i + 1);
        for (j = 0; j < tr; j++)
            scanf("%d", &c[i][j]);
    }

    printf("Enter allocation matrix:\n");
    for (i = 0; i < tp; i++) {
        printf("Process %d:\n", i + 1);
        for (j = 0; j < tr; j++)
            scanf("%d", &p[i][j]);
    }

    printf("Enter resource vector (Total resources):\n");
    for (i = 0; i < tr; i++) {
        scanf("%d", &r[i]);
    }

    printf("Enter availability vector (Available resources):\n");
    for (i = 0; i < tr; i++) {
        scanf("%d", &a[i]);
        temp[i] = a[i];
    }

    // Find processes with no allocation
    for (i = 0; i < tp; i++) {
        sum = 0;
        for (j = 0; j < tr; j++) {
            sum += p[i][j];
        }
        if (sum == 0) {
            m[k] = i;
            k++;
        }
    }

    // Try to find safe sequence
    for (i = 0; i < tp; i++) {
        flag = 1;
        for (l = 0; l < k; l++) {
            if (i == m[l]) {
                flag = 0;
                break;
            }
        }
        if (flag == 1) {
            int canRun = 1;
            for (j = 0; j < tr; j++) {
                if (c[i][j] - p[i][j] > temp[j]) {
                    canRun = 0;
                    break;
                }
            }
            if (canRun) {
                m[k] = i;
                k++;
                for (j = 0; j < tr; j++) {
                    temp[j] += p[i][j];
                }
            }
        }
    }

    printf("Deadlock causing processes are: ");
    for (j = 0; j < tp; j++) {
        found = 0;
        for (i = 0; i < k; i++) {
            if (j == m[i]) {
                found = 1;
                break;
            }
        }
        if (!found)
            printf("%d\t", j + 1);
    }
    printf("\n");

    return 0;
}
